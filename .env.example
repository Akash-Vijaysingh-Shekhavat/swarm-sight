# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Azure AI Foundry ──────────────────────────────────────────
# Your Azure AI Foundry resource name (the subdomain part of your endpoint)
# e.g. if endpoint is https://my-resource.services.ai.azure.com → set "my-resource"
AZURE_RESOURCE_NAME=your-resource-name-here

# Service principal credentials for DefaultAzureCredential
# Create via: az ad sp create-for-rbac --name swarm-sight --role "Cognitive Services User"
AZURE_CLIENT_ID=your-client-id-here
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
